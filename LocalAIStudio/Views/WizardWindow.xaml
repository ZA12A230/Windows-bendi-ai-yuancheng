<Window x:Class="LocalAIStudio.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Local AI Studio - 首次设置向导"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 动画 -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>

        <!-- 蓝色渐变 -->
        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3B82F6" Offset="0"/>
            <GradientStop Color="#2563EB" Offset="1"/>
        </LinearGradientBrush>

        <!-- 按钮样式 -->
        <Style x:Key="NextButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="{StaticResource BlueGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="25" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="buttonTranslate"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#60A5FA" Offset="0"/>
                                            <GradientStop Color="#3B82F6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="2" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SkipButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#1E3A8A" BlurRadius="30" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <!-- 进度指示器 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                <ItemsControl x:Name="ProgressIndicators">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <!-- 跳过按钮 -->
            <Button x:Name="SkipButton" Content="跳过设置" Style="{StaticResource SkipButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0"
                    Click="SkipButton_Click"/>

            <!-- 页面容器 -->
            <Grid x:Name="PageContainer" Margin="0,80,0,100">
                <!-- 欢迎页 -->
                <Grid x:Name="WelcomePage" Visibility="Visible">
                    <Border Background="{StaticResource BlueGradient}" CornerRadius="20" Margin="10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Local AI Studio" FontSize="48" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#1E3A8A" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="您的本地 AI 工作室" FontSize="24" Foreground="White" 
                                       Opacity="0.9" HorizontalAlignment="Center" Margin="0,0,0,60"/>
                            <Button x:Name="WelcomeNextButton" Content="开始设置 →" Style="{StaticResource NextButtonStyle}"
                                    HorizontalAlignment="Center" Click="WelcomeNextButton_Click">
                                <Button.RenderTransform>
                                    <TranslateTransform/>
                                </Button.RenderTransform>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Ollama 检测页 -->
                <Grid x:Name="OllamaPage" Visibility="Collapsed">
                    <StackPanel Margin="60,40">
                        <TextBlock Text="检测 Ollama 安装状态" FontSize="32" FontWeight="Bold" 
                                   Foreground="#1E3A8A" Margin="0,0,0,30"/>

                        <Border x:Name="OllamaStatusBorder" Background="#F0FDF4" BorderBrush="#22C55E" 
                                BorderThickness="2" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="OllamaStatusIcon" Text="✓" FontSize="24" 
                                           Foreground="#22C55E" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="OllamaStatusText" Text="正在检测..." FontSize="18" 
                                           Foreground="#166534" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="下载链接：" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="#374151" Margin="0,0,0,10"/>
                        
                        <Border Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="官网下载：" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                                <TextBox x:Name="OllamaOfficialLink" Text="https://ollama.com/download" 
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                         FontSize="14" Foreground="#2563EB" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="国内加速下载：" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                                <TextBox x:Name="OllamaChinaLink" Text="https://github.com/ollama/ollama/releases"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                         FontSize="14" Foreground="#2563EB" Margin="0,0,0,10"/>

                                <Button Content="复制下载链接" Width="150" Height="35" 
                                        Background="#3B82F6" Foreground="White" FontSize="14"
                                        BorderThickness="0" Cursor="Hand" Click="CopyDownloadLink_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button x:Name="DeployOllamaButton" Content="🚀 一键部署 Ollama" 
                                Width="250" Height="50" FontSize="16" FontWeight="SemiBold"
                                Background="#10B981" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="DeployOllama_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#059669"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock x:Name="DeployStatus" Text="" FontSize="14" 
                                   Foreground="#64748B" Margin="0,15,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- AI 模型选择页 -->
                <Grid x:Name="ModelsPage" Visibility="Collapsed">
                    <StackPanel Margin="60,40">
                        <TextBlock Text="选择 AI 模型" FontSize="32" FontWeight="Bold" 
                                   Foreground="#1E3A8A" Margin="0,0,0,30"/>

                        <Border x:Name="ModelsStatusBorder" Background="#F0FDF4" BorderBrush="#22C55E" 
                                BorderThickness="2" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ModelsStatusIcon" Text="✓" FontSize="24" 
                                           Foreground="#22C55E" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ModelsStatusText" Text="正在检测已安装模型..." FontSize="18" 
                                           Foreground="#166534" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="已安装的模型：" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="#374151" Margin="0,0,0,10"/>
                        
                        <ListBox x:Name="ModelsListBox" Height="150" Margin="0,0,0,20"
                                 BorderBrush="#E5E7EB" BorderThickness="2" Background="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <CheckBox x:Name="ModelCheckBox" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding}" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="安装新模型：" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="#374151" Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBox x:Name="ModelInstallUrl" Width="400" Height="35" FontSize="14"
                                     Text="https://ollama.com/library/" Padding="10,5"/>
                            <Button Content="安装" Width="80" Height="35" Margin="10,0,0,0"
                                    Background="#3B82F6" Foreground="White" FontSize="14"
                                    BorderThickness="0" Cursor="Hand" Click="InstallModel_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <TextBlock x:Name="ModelInstallStatus" Text="" FontSize="14" 
                                   Foreground="#64748B" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- 系统设置页 -->
                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="60,40,60,20">
                        <StackPanel>
                            <TextBlock Text="系统设置" FontSize="32" FontWeight="Bold" 
                                       Foreground="#1E3A8A" Margin="0,0,0,30"/>

                            <!-- 开机自启动 -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="开机自启动" FontSize="18" FontWeight="SemiBold" 
                                                   Foreground="#374151"/>
                                        <TextBlock Text="系统启动时自动运行程序" FontSize="14" 
                                                   Foreground="#64748B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="AutoStartToggle" HorizontalAlignment="Right" 
                                                  VerticalAlignment="Center" Width="60" Height="30"
                                                  Click="AutoStartToggle_Click">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="border" Background="#E5E7EB" CornerRadius="15">
                                                    <Ellipse x:Name="thumb" Width="26" Height="26" 
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- 管理员运行 -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="管理员权限运行" FontSize="18" FontWeight="SemiBold" 
                                                   Foreground="#374151"/>
                                        <TextBlock Text="以管理员身份运行程序" FontSize="14" 
                                                   Foreground="#64748B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="AdminToggle" HorizontalAlignment="Right" 
                                                  VerticalAlignment="Center" Width="60" Height="30">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="border" Background="#E5E7EB" CornerRadius="15">
                                                    <Ellipse x:Name="thumb" Width="26" Height="26" 
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- 息屏功能 -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="息屏替代关机" FontSize="18" FontWeight="SemiBold" 
                                                   Foreground="#374151"/>
                                        <TextBlock Text="将关机按钮替换为息屏，只有电源键可以唤醒" FontSize="14" 
                                                   Foreground="#64748B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ScreenOffToggle" HorizontalAlignment="Right" 
                                                  VerticalAlignment="Center" Width="60" Height="30">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="border" Background="#E5E7EB" CornerRadius="15">
                                                    <Ellipse x:Name="thumb" Width="26" Height="26" 
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- 静默启动 -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="静默启动模式" FontSize="18" FontWeight="SemiBold" 
                                                   Foreground="#374151"/>
                                        <TextBlock Text="启动时不显示窗口，自动进入托盘模式" FontSize="14" 
                                                   Foreground="#64748B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="SilentStartToggle" HorizontalAlignment="Right" 
                                                  VerticalAlignment="Center" Width="60" Height="30">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="border" Background="#E5E7EB" CornerRadius="15">
                                                    <Ellipse x:Name="thumb" Width="26" Height="26" 
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- 自适应模式 -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="自适应模式" FontSize="18" FontWeight="SemiBold" 
                                                   Foreground="#374151"/>
                                        <TextBlock Text="自动调整 AI 进程优先级，保证系统流畅运行" FontSize="14" 
                                                   Foreground="#64748B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="AdaptiveModeToggle" HorizontalAlignment="Right" 
                                                  VerticalAlignment="Center" Width="60" Height="30"
                                                  IsChecked="True">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="border" Background="#E5E7EB" CornerRadius="15">
                                                    <Ellipse x:Name="thumb" Width="26" Height="26" 
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- 内网穿透配置页 -->
                <Grid x:Name="FrpPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="60,40,60,20">
                        <StackPanel>
                            <TextBlock Text="内网穿透配置" FontSize="32" FontWeight="Bold" 
                                       Foreground="#1E3A8A" Margin="0,0,0,30"/>

                            <TextBlock Text="在非局域网环境下远程访问您的电脑" FontSize="16" 
                                       Foreground="#64748B" Margin="0,0,0,30"/>

                            <!-- 启用内网穿透 -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="启用内网穿透功能" FontSize="18" FontWeight="SemiBold" 
                                                   Foreground="#374151"/>
                                        <TextBlock Text="通过 frp 服务实现远程访问" FontSize="14" 
                                                   Foreground="#64748B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="FrpEnableToggle" HorizontalAlignment="Right" 
                                                  VerticalAlignment="Center" Width="60" Height="30">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="border" Background="#E5E7EB" CornerRadius="15">
                                                    <Ellipse x:Name="thumb" Width="26" Height="26" 
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- 配置表单 -->
                            <StackPanel x:Name="FrpConfigPanel" Visibility="Collapsed">
                                <TextBlock Text="服务器地址" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="#374151" Margin="0,0,0,5"/>
                                <TextBox x:Name="FrpServerAddress" Text="frp.example.com" 
                                         Height="40" FontSize="14" Padding="10,8" Margin="0,0,0,15"/>

                                <TextBlock Text="服务器端口" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="#374151" Margin="0,0,0,5"/>
                                <TextBox x:Name="FrpServerPort" Text="7000" 
                                         Height="40" FontSize="14" Padding="10,8" Margin="0,0,0,15"/>

                                <TextBlock Text="认证令牌" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="#374151" Margin="0,0,0,5"/>
                                <TextBox x:Name="FrpAuthToken" Height="40" FontSize="14" Padding="10,8" Margin="0,0,0,15"/>

                                <TextBlock Text="自定义子域名（可选）" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="#374151" Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="http://www.aiyuancheng.com." FontSize="14" 
                                               Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="FrpSubdomain" Width="200" Height="40" FontSize="14" Padding="10,8"/>
                                </StackPanel>

                                <Border Background="#FEF3C7" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="⚠️ 重要信息" FontSize="14" FontWeight="Bold" 
                                                   Foreground="#92400E" Margin="0,0,0,10"/>
                                        <TextBlock Text="访问地址格式：http://www.aiyuancheng.com.{自定义域名}" 
                                                   FontSize="13" Foreground="#92400E" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- IPv4 配置 -->
                            <TextBlock Text="本地 IPv4 地址配置" FontSize="18" FontWeight="Bold" 
                                       Foreground="#374151" Margin="0,20,0,15"/>

                            <Border Background="#EFF6FF" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="自动检测到的 IPv4 地址：" FontSize="14" 
                                               Foreground="#374151" Margin="0,0,0,10"/>
                                    <TextBox x:Name="LocalIPv4Text" IsReadOnly="True" 
                                             Height="40" FontSize="16" FontWeight="SemiBold"
                                             Background="White" Foreground="#3B82F6" Padding="10,8"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="账号信息（必填）" FontSize="18" FontWeight="Bold" 
                                       Foreground="#374151" Margin="0,20,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="用户名（纯英文）" FontSize="14" FontWeight="SemiBold" 
                                               Foreground="#374151" Margin="0,0,0,5"/>
                                    <TextBox x:Name="UsernameText" Height="40" FontSize="14" Padding="10,8"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="密码（英文+数字）" FontSize="14" FontWeight="SemiBold" 
                                               Foreground="#374151" Margin="0,0,0,5"/>
                                    <PasswordBox x:Name="PasswordBox" Height="40" FontSize="14" Padding="10,8"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- 远程桌面说明页 -->
                <Grid x:Name="RemoteDesktopPage" Visibility="Collapsed">
                    <StackPanel Margin="60,40">
                        <TextBlock Text="远程桌面功能" FontSize="32" FontWeight="Bold" 
                                   Foreground="#1E3A8A" Margin="0,0,0,30"/>

                        <Border Background="#EFF6FF" CornerRadius="12" Padding="30" Margin="0,0,0,20">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🖥️" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock Text="类似 ToDesk 的远程桌面" FontSize="24" FontWeight="Bold" 
                                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <TextBlock Text="通过内网穿透，在任何网络环境下远程控制您的电脑" 
                                           FontSize="16" Foreground="#64748B" HorizontalAlignment="Center" 
                                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                                <TextBlock Text="功能特点：" FontSize="18" FontWeight="Bold" 
                                           Foreground="#374151" Margin="0,0,0,10"/>
                                <StackPanel Margin="20,0,0,0">
                                    <TextBlock Text="✓ 实时屏幕共享" FontSize="14" Foreground="#64748B" Margin="0,5"/>
                                    <TextBlock Text="✓ 鼠标键盘远程控制" FontSize="14" Foreground="#64748B" Margin="0,5"/>
                                    <TextBlock Text="✓ 跨平台访问" FontSize="14" Foreground="#64748B" Margin="0,5"/>
                                    <TextBlock Text="✓ 安全加密连接" FontSize="14" Foreground="#64748B" Margin="0,5"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#F0FDF4" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="远程桌面功能需要配置内网穿透" FontSize="14" 
                                           Foreground="#166534" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 硬件检测说明页 -->
                <Grid x:Name="HardwarePage" Visibility="Collapsed">
                    <StackPanel Margin="60,40">
                        <TextBlock Text="硬件检测功能" FontSize="32" FontWeight="Bold" 
                                   Foreground="#1E3A8A" Margin="0,0,0,30"/>

                        <TextBlock Text="在远程端实时查看主机硬件状态" FontSize="18" 
                                   Foreground="#64748B" Margin="0,0,0,30"/>

                        <WrapPanel HorizontalAlignment="Center">
                            <!-- 摄像头 -->
                            <Border Background="#FEF3C7" CornerRadius="12" Padding="25" Width="250" Margin="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="摄像头监控" FontSize="18" FontWeight="Bold" 
                                               Foreground="#92400E" HorizontalAlignment="Center"/>
                                    <TextBlock Text="实时画面捕获" FontSize="14" 
                                               Foreground="#B45309" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- 麦克风 -->
                            <Border Background="#DBEAFE" CornerRadius="12" Padding="25" Width="250" Margin="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🎤" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="麦克风录音" FontSize="18" FontWeight="Bold" 
                                               Foreground="#1E40AF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="远程对讲功能" FontSize="14" 
                                               Foreground="#1D4ED8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- WiFi -->
                            <Border Background="#E0E7FF" CornerRadius="12" Padding="25" Width="250" Margin="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📶" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="WiFi 信息" FontSize="18" FontWeight="Bold" 
                                               Foreground="#3730A3" HorizontalAlignment="Center"/>
                                    <TextBlock Text="连接状态和强度" FontSize="14" 
                                               Foreground="#4338CA" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- USB -->
                            <Border Background="#F3E8FF" CornerRadius="12" Padding="25" Width="250" Margin="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔌" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="USB 设备" FontSize="18" FontWeight="Bold" 
                                               Foreground="#6B21A8" HorizontalAlignment="Center"/>
                                    <TextBlock Text="设备列表查看" FontSize="14" 
                                               Foreground="#7C3AED" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Wrap>

                        <Border Background="#F0FDF4" CornerRadius="12" Padding="20" Margin="0,30,0,0">
                            <StackPanel>
                                <TextBlock Text="💡 提示" FontSize="16" FontWeight="Bold" 
                                           Foreground="#166534" Margin="0,0,0,10"/>
                                <TextBlock Text="所有硬件访问都通过 RESTful API 提供，可以通过 HTTP 请求获取实时数据。" 
                                           FontSize="14" Foreground="#166534" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Web 服务器说明页 -->
                <Grid x:Name="WebServerPage" Visibility="Collapsed">
                    <StackPanel Margin="60,40">
                        <TextBlock Text="网站服务器功能" FontSize="32" FontWeight="Bold" 
                                   Foreground="#1E3A8A" Margin="0,0,0,30"/>

                        <TextBlock Text="在本地托管网站，通过远程访问" FontSize="18" 
                                   Foreground="#64748B" Margin="0,0,0,30"/>

                        <Border Background="#EFF6FF" CornerRadius="12" Padding="30" Margin="0,0,0,20">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🌐" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock Text="内置 HTTP 服务器" FontSize="24" FontWeight="Bold" 
                                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                                    <Border Background="White" CornerRadius="8" Padding="15" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="静态文件" FontSize="14" FontWeight="Bold" 
                                                       Foreground="#374151" HorizontalAlignment="Center"/>
                                            <TextBlock Text="HTML/CSS/JS" FontSize="12" 
                                                       Foreground="#64748B" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="White" CornerRadius="8" Padding="15" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="多站点" FontSize="14" FontWeight="Bold" 
                                                       Foreground="#374151" HorizontalAlignment="Center"/>
                                            <TextBlock Text="同时托管多个" FontSize="12" 
                                                       Foreground="#64748B" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="White" CornerRadius="8" Padding="15" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="内网穿透" FontSize="14" FontWeight="Bold" 
                                                       Foreground="#374151" HorizontalAlignment="Center"/>
                                            <TextBlock Text="公网访问" FontSize="12" 
                                                       Foreground="#64748B" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="White" CornerRadius="8" Padding="15" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="自定义域名" FontSize="14" FontWeight="Bold" 
                                                       Foreground="#374151" HorizontalAlignment="Center"/>
                                            <TextBlock Text="绑定专属域名" FontSize="12" 
                                                       Foreground="#64748B" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Wrap>
                            </StackPanel>
                        </Border>

                        <Border Background="#FEF3C7" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="💡 使用方法" FontSize="16" FontWeight="Bold" 
                                           Foreground="#92400E" Margin="0,0,0,10"/>
                                <TextBlock Text="1. 添加网站，指定网站根目录" FontSize="14" 
                                           Foreground="#B45309" Margin="0,5,0,0"/>
                                <TextBlock Text="2. 设置监听端口" FontSize="14" 
                                           Foreground="#B45309" Margin="0,5,0,0"/>
                                <TextBlock Text="3. 启动服务器即可访问" FontSize="14" 
                                           Foreground="#B45309" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 完成页 -->
                <Grid x:Name="CompletePage" Visibility="Collapsed">
                    <Border Background="{StaticResource BlueGradient}" CornerRadius="20" Margin="10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🎉" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="设置完成！" FontSize="42" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#1E3A8A" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="感谢您选择 Local AI Studio" FontSize="20" 
                                       Foreground="White" Opacity="0.9" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                            <Button Content="开始使用 →" Style="{StaticResource NextButtonStyle}"
                                    HorizontalAlignment="Center" Click="StartUsingButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- 底部导航 -->
            <Grid Height="80" VerticalAlignment="Bottom" Margin="0,0,0,10">
                <Button x:Name="BackButton" Content="← 上一步" Width="120" Height="40"
                        Background="#F1F5F9" Foreground="#64748B" FontSize="14"
                        BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Margin="60,0,0,0"
                        Click="BackButton_Click" Visibility="Collapsed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="NextButton" Content="下一步 →" Style="{StaticResource NextButtonStyle}"
                        HorizontalAlignment="Right" Margin="0,0,60,0" Click="NextButton_Click">
                    <Button.RenderTransform>
                        <TranslateTransform/>
                    </Button.RenderTransform>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
