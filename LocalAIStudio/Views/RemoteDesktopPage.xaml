<UserControl x:Class="LocalAIStudio.Views.RemoteDesktopPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="650">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="远程桌面" FontSize="32" FontWeight="Bold" 
                       Foreground="#3B82F6" Margin="0,0,0,20"/>

            <!-- 状态提示 -->
            <Border Background="#F0F9FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" 
                             Fill="#94A3B8" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="未启用" FontSize="14" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- 服务说明 -->
            <Border Background="#FFFBEB" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="使用说明" FontSize="14" FontWeight="Medium" Foreground="#D97706" Margin="0,0,0,5"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#78350F">
                        <Run>远程桌面基于 VNC 协议实现。建议下载 UltraVNC (https://www.uvnc.com/) 服务端程序并放置在应用目录下。</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#78350F" Margin="0,5,0,0">
                        <Run>客户端可用 UltraVNC Viewer、RealVNC Viewer 或浏览器 Web 客户端（如 noVNC）连接。</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 开启开关 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="启用远程桌面" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                        <TextBlock Text="启用后本机作为被控端" FontSize="12" Foreground="#64748B" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="EnableRdpToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="EnableRdpToggle_Changed"
                                  Unchecked="EnableRdpToggle_Changed"/>
                </Grid>
            </Border>

            <!-- 认证信息 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="认证信息" FontSize="15" FontWeight="Medium" Foreground="#333333" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="用户名" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameTextBox" Style="{StaticResource ModernTextBox}" 
                             MaxLength="20" Margin="0,0,0,10"/>
                    <TextBlock x:Name="UsernameErrorText" Text="" FontSize="12" Foreground="#EF4444" 
                               Visibility="Collapsed" Margin="0,-8,0,10"/>

                    <TextBlock Text="密码" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernTextBox}" />
                    <TextBlock x:Name="PasswordErrorText" Text="" FontSize="12" Foreground="#EF4444" 
                               Visibility="Collapsed" Margin="0,5,0,10"/>

                    <TextBlock Text="端口" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox x:Name="PortTextBox" Style="{StaticResource ModernTextBox}" 
                             Text="5900" MaxLength="5" Margin="0,0,0,5"/>
                    <TextBlock x:Name="PortErrorText" Text="" FontSize="12" Foreground="#EF4444" 
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 内网穿透 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="启用公网穿透" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                        <TextBlock Text="通过内网穿透实现跨局域网访问" FontSize="12" Foreground="#64748B" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="EnableFrpToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="EnableFrpToggle_Changed"
                                  Unchecked="EnableFrpToggle_Changed"/>
                </Grid>
            </Border>

            <!-- 自定义子域名 -->
            <Border x:Name="CustomDomainSection" Background="#F0F9FF" CornerRadius="12" 
                    Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="自定义子域名（可选）" FontSize="14" FontWeight="Medium" Foreground="#3B82F6"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="http://" FontSize="13" Foreground="#64748B" 
                                   VerticalAlignment="Center" Padding="8,0"/>
                        
                        <TextBox x:Name="CustomDomainTextBox" Style="{StaticResource ModernTextBox}" 
                                 Grid.Column="1"/>
                        
                        <TextBlock Text=".aiyuancheng.com" FontSize="13" Foreground="#64748B" 
                                   VerticalAlignment="Center" Padding="8,0" Grid.Column="2"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button x:Name="SaveButton" Content="保存配置" 
                        Width="120" Height="45"
                        Style="{StaticResource ModernButton}"
                        Background="#3B82F6"
                        Click="SaveButton_Click"/>

                <Button x:Name="StartStopButton" Content="启动服务" 
                        Width="120" Height="45"
                        Margin="15,0,0,0"
                        Style="{StaticResource ModernButton}"
                        Background="#10B981"
                        Click="StartStopButton_Click"/>
            </StackPanel>

            <!-- 访问信息 -->
            <Border x:Name="AccessInfoSection" Background="#ECFDF5" CornerRadius="12" 
                    Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="连接信息" FontSize="14" FontWeight="Medium" Foreground="#065F46"/>
                    
                    <TextBlock x:Name="LocalAccessText" Text="" TextWrapping="Wrap" 
                               FontSize="13" Foreground="#065F46" Margin="0,8,0,0"/>
                    
                    <TextBlock x:Name="RemoteAccessText" Text="" TextWrapping="Wrap" 
                               FontSize="13" Foreground="#065F46" Margin="0,5,0,0"
                               Visibility="Collapsed"/>
                    
                    <Button x:Name="ShowGuideButton" Content="显示连接指南" 
                            Width="140" Height="40"
                            Margin="0,15,0,0"
                            Style="{StaticResource ModernButton}"
                            Background="#059669"
                            Click="ShowGuideButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
