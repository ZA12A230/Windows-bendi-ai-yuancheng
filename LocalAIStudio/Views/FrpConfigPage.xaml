<UserControl x:Class="LocalAIStudio.Views.FrpConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LocalAIStudio.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="650">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="内网穿透配置" FontSize="32" FontWeight="Bold" 
                       Foreground="#3B82F6" Margin="0,0,0,20"/>

            <!-- 状态提示 -->
            <Border Background="#F0F9FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" 
                             Fill="#94A3B8" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="未连接" FontSize="14" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- 服务说明 -->
            <Border Background="#FFFBEB" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="提示" FontSize="14" FontWeight="Medium" Foreground="#D97706" Margin="0,0,0,5"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#78350F">
                        <Run>内网穿透功能需要 frpc.exe 才能正常工作。请从 </Run>
                        <Hyperlink NavigateUri="https://github.com/fatedier/frp/releases" 
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="frp Releases"/>
                        </Hyperlink>
                        <Run> 下载对应版本的 frpc.exe 并放置在应用程序同一目录下。</Run>
                    </TextBlock>
                    <TextBlock Text="您也可以使用自建的 frp 服务端，或使用已有的公开穿透服务。" 
                               TextWrapping="Wrap" FontSize="13" Foreground="#78350F" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- 浏览器地址 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="浏览器地址" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                    <TextBlock Text="例如：http://localhost:8080" FontSize="12" Foreground="#64748B" Margin="0,3,0,10"/>
                    <TextBox x:Name="BrowserUrlTextBox" 
                             Style="{StaticResource ModernTextBox}"
                             Text="http://localhost:8080"/>
                </StackPanel>
            </Border>

            <!-- IPv4地址 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="IPv4地址" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                    <TextBlock Text="系统已自动检测网段，请填写最后一段" FontSize="12" Foreground="#64748B" Margin="0,3,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock x:Name="IpPrefixText" Text="192.168.1." 
                                   FontSize="14" Foreground="#64748B" 
                                   VerticalAlignment="Center" 
                                   Padding="8,0"/>
                        
                        <TextBox x:Name="IpLastSegmentTextBox" 
                                 Style="{StaticResource ModernTextBox}"
                                 Grid.Column="1"
                                 MaxLength="3"
                                 PreviewTextInput="IpLastSegmentTextBox_PreviewTextInput"/>
                    </Grid>
                    <TextBlock x:Name="IpErrorText" Text="" FontSize="12" Foreground="#EF4444" Margin="0,5,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 账号名 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="账号名" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                    <TextBlock Text="仅允许英文字母、数字和下划线" FontSize="12" Foreground="#64748B" Margin="0,3,0,10"/>
                    <TextBox x:Name="UsernameTextBox" 
                             Style="{StaticResource ModernTextBox}"/>
                    <TextBlock x:Name="UsernameErrorText" Text="" FontSize="12" Foreground="#EF4444" Margin="0,5,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 密码 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="密码" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                    <TextBlock Text="必须包含英文和数字的组合" FontSize="12" Foreground="#64748B" Margin="0,3,0,10"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernTextBox}" />
                    <TextBlock x:Name="PasswordErrorText" Text="" FontSize="12" Foreground="#EF4444" Margin="0,5,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 内网穿透开关 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="开启内网穿透" FontSize="15" FontWeight="Medium" Foreground="#333333"/>
                        <TextBlock Text="将本地服务暴露到公网" FontSize="12" Foreground="#64748B" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="EnableFrpToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="EnableFrpToggle_Changed"
                                  Unchecked="EnableFrpToggle_Changed"/>
                </Grid>
            </Border>

            <!-- 自定义子域名 -->
            <Border x:Name="SubdomainSection" Background="#F0F9FF" CornerRadius="12" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="内网穿透自定义子域名" FontSize="15" FontWeight="Medium" Foreground="#3B82F6"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="http://" FontSize="14" Foreground="#64748B" 
                                   VerticalAlignment="Center" Padding="8,0"/>
                        
                        <TextBox x:Name="CustomSubdomainTextBox" 
                                 Style="{StaticResource ModernTextBox}"
                                 Grid.Column="1"/>
                        
                        <TextBlock Text=".aiyuancheng.com" FontSize="14" Foreground="#64748B" 
                                   VerticalAlignment="Center" Padding="8,0" Grid.Column="2"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button x:Name="SaveButton" Content="保存配置" 
                        Width="120" Height="45"
                        Style="{StaticResource ModernButton}"
                        Background="#3B82F6"
                        Click="SaveButton_Click"/>

                <Button x:Name="StartStopButton" Content="启动服务" 
                        Width="120" Height="45"
                        Margin="15,0,0,0"
                        Style="{StaticResource ModernButton}"
                        Background="#10B981"
                        Click="StartStopButton_Click"/>
            </StackPanel>

            <!-- 访问地址显示 -->
            <Border x:Name="AccessInfoSection" Background="#ECFDF5" CornerRadius="12" Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="访问地址" FontSize="14" FontWeight="Medium" Foreground="#065F46"/>
                    
                    <TextBlock x:Name="LocalAccessUrl" Text="" 
                               TextWrapping="Wrap" FontSize="13" Foreground="#065F46" Margin="0,8,0,0"/>
                    
                    <TextBlock x:Name="RemoteAccessUrl" Text="" 
                               TextWrapping="Wrap" FontSize="13" Foreground="#065F46" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
