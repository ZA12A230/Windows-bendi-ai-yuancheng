<UserControl x:Class="LocalAIStudio.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LocalAIStudio.Views"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="650">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="设置" FontSize="32" FontWeight="Bold" 
                       Foreground="#3B82F6" Margin="0,0,0,20"/>

            <!-- 开机自启动 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="开启开机自启动" FontSize="15" FontWeight="Medium" 
                                   Foreground="#333333"/>
                        <TextBlock Text="应用程序将在系统启动时自动运行" 
                                   FontSize="12" Foreground="#666666" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="AutoStartToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="ToggleButton_Changed"
                                  Unchecked="ToggleButton_Changed"/>
                </Grid>
            </Border>

            <!-- 自动以管理员运行 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="自动以管理员运行" FontSize="15" FontWeight="Medium" 
                                   Foreground="#333333"/>
                        <TextBlock Text="下次启动时将自动提升权限" 
                                   FontSize="12" Foreground="#666666" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="AdminModeToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="ToggleButton_Changed"
                                  Unchecked="ToggleButton_Changed"/>
                </Grid>
            </Border>

            <!-- 调换开机键 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="替换关机为息屏" FontSize="15" FontWeight="Medium" 
                                   Foreground="#333333"/>
                        <TextBlock Text="开始菜单关机按钮变为息屏，需电源键唤醒" 
                                   FontSize="12" Foreground="#666666" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="ScreenOffToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="ToggleButton_Changed"
                                  Unchecked="ToggleButton_Changed"/>
                </Grid>
            </Border>

            <!-- 静默启动 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="静默启动" FontSize="15" FontWeight="Medium" 
                                   Foreground="#333333"/>
                        <TextBlock Text="下次启动不显示主窗口，直接托盘运行" 
                                   FontSize="12" Foreground="#666666" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="SilentStartToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="ToggleButton_Changed"
                                  Unchecked="ToggleButton_Changed"/>
                </Grid>
            </Border>

            <!-- 自适应模式 -->
            <Border Background="#F5F8FF" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="自适应模式" FontSize="15" FontWeight="Medium" 
                                   Foreground="#333333"/>
                        <TextBlock Text="根据系统负载动态调整AI优先级（CPU>80%时降速）" 
                                   FontSize="12" Foreground="#666666" Margin="0,3,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="AdaptiveModeToggle" Grid.Column="1" 
                                  Style="{StaticResource CustomToggleSwitch}"
                                  Checked="ToggleButton_Changed"
                                  Unchecked="ToggleButton_Changed"/>
                </Grid>
            </Border>

            <!-- 自适应模式配置 -->
            <Border x:Name="AdaptiveConfigBorder" 
                    Background="#F0F5FF" CornerRadius="12" 
                    Padding="20" Margin="0,0,0,15"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="自适应模式配置" FontSize="14" FontWeight="Medium" 
                               Foreground="#3B82F6" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="系统总CPU占用阈值 (%)" 
                                   FontSize="13" Foreground="#555555" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="CpuThresholdBox" Grid.Column="1" 
                                 Text="80" Style="{StaticResource ModernTextBox}"
                                 MaxLength="3"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="AI模型占用阈值 (%)" 
                                   FontSize="13" Foreground="#555555" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="AiThresholdBox" Grid.Column="1" 
                                 Text="50" Style="{StaticResource ModernTextBox}"
                                 MaxLength="3"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <Button Content="保存设置" 
                    Width="150" Height="40"
                    HorizontalAlignment="Left"
                    Style="{StaticResource ModernButton}"
                    Background="#3B82F6"
                    Click="SaveButton_Click"
                    Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
