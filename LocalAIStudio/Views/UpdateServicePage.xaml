<UserControl x:Class="LocalAIStudio.Views.UpdateServicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="🔄 服务守护与更新" FontSize="28" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                <!-- 守护进程状态 -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="守护进程" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="服务监控状态" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="WatchdogStatusText" Text="运行中" FontSize="18" FontWeight="Bold" 
                                           Foreground="{StaticResource SuccessGreen}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <ToggleButton x:Name="WatchdogToggle" Grid.Column="1" 
                                         Style="{StaticResource ToggleSwitch}"
                                         IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="监控的服务进程：" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="0,0,0,10"/>

                        <ItemsControl x:Name="MonitoredProcessesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" 
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding ExePath}" FontSize="11" 
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource SuccessGreen}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock VerticalAlignment="Center" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="已停止"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Text" Value="运行中"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessGreen}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 自适应模式 -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="自适应模式" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="动态调整AI进程优先级" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="当系统资源紧张时自动降低AI占用" FontSize="11" 
                                           Foreground="#94A3B8" Margin="0,3,0,0"/>
                            </StackPanel>

                            <ToggleButton x:Name="AdaptiveModeToggle" Grid.Column="1" 
                                         Style="{StaticResource ToggleSwitch}"
                                         VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="系统CPU阈值 (%)" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="SystemThresholdText" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                     Text="80"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="AI进程CPU阈值 (%)" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="AiThresholdText" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                     Text="50"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 自更新 -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="自动更新" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="当前版本" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="CurrentVersionText" Text="v1.0.0" FontSize="18" FontWeight="Bold" 
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="检查更新" Style="{StaticResource PrimaryButton}"
                                    Click="CheckUpdate_Click" VerticalAlignment="Center"/>
                        </Grid>

                        <Border x:Name="UpdateAvailableBorder" Background="#ECFDF5" CornerRadius="12" 
                                Padding="15" Visibility="Collapsed" Margin="0,0,0,15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="发现新版本：" FontSize="13" Foreground="#065F46"/>
                                    <TextBlock x:Name="NewVersionText" Text="v1.1.0" FontSize="13" FontWeight="Bold" 
                                               Foreground="#059669" Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="ReleaseNotesText" Text="" FontSize="12" 
                                           Foreground="#047857" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <Button x:Name="DownloadUpdateButton" Content="下载并安装" 
                                        Style="{StaticResource PrimaryButton}" Margin="0,15,0,0"
                                        Click="DownloadUpdate_Click"/>
                            </StackPanel>
                        </Border>

                        <ProgressBar x:Name="DownloadProgress" Style="{StaticResource ModernProgressBar}" 
                                     Height="8" Visibility="Collapsed" Margin="0,0,0,10"/>

                        <TextBlock x:Name="UpdateStatusText" Text="" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                    </StackPanel>
                </Border>

                <!-- 静默启动 -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="启动选项" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="静默启动" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="启动时不显示主窗口，直接进入托盘模式" FontSize="11" 
                                           Foreground="#94A3B8" Margin="0,3,0,0"/>
                            </StackPanel>

                            <ToggleButton x:Name="SilentStartToggle" Grid.Column="1" 
                                         Style="{StaticResource ToggleSwitch}"
                                         VerticalAlignment="Center" Checked="SilentStartToggle_Changed"
                                         Unchecked="SilentStartToggle_Changed"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
