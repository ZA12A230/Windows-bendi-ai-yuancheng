<UserControl x:Class="LocalAIStudio.Views.WebServerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="850">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🌐 网站服务器" FontSize="28" FontWeight="Bold" Foreground="#3B82F6"/>
            <TextBlock Text="托管本地HTML网站，支持多站点和内网穿透" FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- 网站列表 -->
            <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ 添加网站" Width="140" Height="40" Style="{StaticResource ModernButton}"
                                Background="#3B82F6" Click="AddWebsite_Click"/>
                        <Button Content="▶ 全部启动" Width="110" Height="40" Margin="10,0,0,0"
                                Style="{StaticResource ModernButton}" Background="#10B981" Click="StartAll_Click"/>
                        <Button Content="⏹ 全部停止" Width="110" Height="40" Margin="10,0,0,0"
                                Style="{StaticResource ModernButton}" Background="#6C757D" Click="StopAll_Click"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" x:Name="WebsiteListBox" Background="Transparent" 
                             BorderThickness="0" SelectionChanged="WebsiteListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Medium" Foreground="#333"/>
                                            <TextBlock Text="{Binding RootPath}" FontSize="11" Foreground="#94A3B8" 
                                                       TextTrimming="CharacterEllipsis" Margin="0,5,0,0" MaxWidth="350"/>
                                            
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Border Background="#E8F0FE" CornerRadius="5" Padding="8,3">
                                                    <TextBlock Text="{Binding LocalUrl}" FontSize="12" Foreground="#3B82F6"/>
                                                </Border>
                                                <Border Background="#ECFDF5" CornerRadius="5" Padding="8,3" Margin="5,0,0,0"
                                                        Visibility="{Binding PublicUrl, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding PublicUrl}" FontSize="12" Foreground="#059669"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#CBD5E1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Fill" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Button Content="▶" Width="35" Height="35" FontSize="14"
                                                    Style="{StaticResource ModernButton}" Background="#10B981"
                                                    Click="ToggleWebsite_Click" Tag="{Binding Id}"/>
                                            <Button Content="🗑" Width="35" Height="35" FontSize="12" Margin="5,0,0,0"
                                                    Style="{StaticResource ModernButton}" Background="#EF4444"
                                                    Click="DeleteWebsite_Click" Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="1" x:Name="EmptyHint" Text="暂无网站，点击上方按钮添加" 
                               FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" 
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- 详细信息面板 -->
            <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="网站详情" FontSize="18" FontWeight="Medium" Foreground="#333" Margin="0,0,0,20"/>

                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="基本信息" FontSize="14" FontWeight="Medium" Foreground="#3B82F6" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="名称" FontSize="12" Foreground="#64748B"/>
                                <TextBox x:Name="WebsiteNameText" Style="{StaticResource ModernTextBox}" Margin="0,5,0,10"
                                         TextChanged="WebsiteNameText_TextChanged"/>

                                <TextBlock Text="端口" FontSize="12" Foreground="#64748B"/>
                                <TextBox x:Name="WebsitePortText" Style="{StaticResource ModernTextBox}" Margin="0,5,0,10"
                                         TextChanged="WebsitePortText_TextChanged"/>

                                <TextBlock Text="路径" FontSize="12" Foreground="#64748B"/>
                                <TextBox x:Name="WebsitePathText" Style="{StaticResource ModernTextBox}" 
                                         IsReadOnly="True" Margin="0,5,0,10"/>
                                
                                <Button Content="📂 浏览..." Width="100" Height="32" Style="{StaticResource ModernButton}"
                                        Background="#6C757D" HorizontalAlignment="Left" Click="BrowseFolder_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="内网穿透" FontSize="14" FontWeight="Medium" Foreground="#3B82F6" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="自定义域名（可选）" FontSize="12" Foreground="#64748B"/>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="http://" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <TextBox x:Name="CustomDomainText" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                             TextChanged="CustomDomainText_TextChanged"/>
                                    <TextBlock Text=".aiyuancheng.com" Grid.Column="2" FontSize="11" Foreground="#64748B" 
                                               VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="文件上传" FontSize="14" FontWeight="Medium" Foreground="#3B82F6" Margin="0,0,0,10"/>
                                
                                <Button Content="📤 上传文件夹" Width="140" Height="35" Style="{StaticResource ModernButton}"
                                        Background="#3B82F6" Click="UploadFolder_Click"/>
                                
                                <Button Content="📄 上传文件" Width="140" Height="35" Margin="0,8,0,0"
                                        Style="{StaticResource ModernButton}" Background="#10B981"
                                        Click="UploadFile_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="15">
                            <StackPanel>
                                <TextBlock Text="访问统计" FontSize="14" FontWeight="Medium" Foreground="#3B82F6" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="访问次数" FontSize="12" Foreground="#64748B"/>
                                <TextBlock x:Name="AccessCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,5,0,0"/>
                                
                                <TextBlock Text="最后访问" FontSize="12" Foreground="#64748B" Margin="0,10,0,0"/>
                                <TextBlock x:Name="LastAccessText" Text="-" FontSize="13" Foreground="#333"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
