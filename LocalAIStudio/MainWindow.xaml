<Window x:Class="LocalAIStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Local AI Studio" Height="580" Width="780"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <Window.Resources>
        <tb:TaskbarIcon x:Key="NotifyIcon" ToolTipText="Local AI Studio"
                        TrayMouseDoubleClick="NotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示窗口" Click="ShowWindowMenuItem_Click"/>
                    <MenuItem Header="退出" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Window.Resources>

    <Grid>
        <Border x:Name="WindowBorder" Background="#FFFFFF" 
                CornerRadius="20" BorderBrush="#E0E8FF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="30" ShadowDepth="0"/>
            </Border.Effect>
        </Border>

        <Grid x:Name="MainGrid" Opacity="0" RenderTransformOrigin="0.5, 0.5">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
            </Grid.RenderTransform>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="15,0">
                        <TextBlock Text="Local AI Studio" FontSize="14" FontWeight="Medium"
                                   Foreground="#444444" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10">
                        <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                                Width="30" Height="30" Content="─" FontSize="12"
                                Background="Transparent" Foreground="#666666"
                                BorderThickness="0" Padding="0"/>
                        <Button x:Name="CloseButton" Click="CloseButton_Click"
                                Width="30" Height="30" Content="✕" FontSize="12"
                                Background="Transparent" Foreground="#666666"
                                BorderThickness="0" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 侧边栏 -->
                <Border Grid.Column="0" Background="#F8FAFC" 
                        CornerRadius="0,0,0,20" Padding="15,20">
                    <StackPanel>
                        <Button x:Name="HomeNavButton" Content="首页" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="HomeNavButton_Click"
                                Tag="0"/>
                        <Button x:Name="ModelsNavButton" Content="模型管理" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="ModelsNavButton_Click"
                                Tag="1"/>
                        <Button x:Name="FrpNavButton" Content="内网穿透" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="FrpNavButton_Click"
                                Tag="2"/>
                        <Button x:Name="RemoteDesktopNavButton" Content="远程桌面" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="RemoteDesktopNavButton_Click"
                                Tag="3"/>
                        <Button x:Name="HardwareMonitorNavButton" Content="硬件监控" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="HardwareMonitorNavButton_Click"
                                Tag="4"/>
                        <Button x:Name="SettingsNavButton" Content="设置" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="SettingsNavButton_Click"
                                Tag="5"/>
                    </StackPanel>
                </Border>

                <!-- 内容区 -->
                <ContentControl x:Name="PageContent" Grid.Column="1" Margin="30,25"/>
            </Grid>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style TargetType="Button" x:Key="NavButtonStyle">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F0FE" TargetName="Border"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
