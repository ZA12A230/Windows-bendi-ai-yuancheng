<Page x:Class="LocalAIAssistant.Views.Pages.WebServerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Web服务">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Web服务" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="服务状态" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Ellipse x:Name="ServerStatusIndicator" Width="12" Height="12" Fill="#EF4444"/>
                        <TextBlock x:Name="ServerStatusText" Text="未启动" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="ServerUrlText" Text="访问地址: -" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="StartServerButton" Content="启动服务" Style="{StaticResource ModernButton}"
                            Padding="20,12" Click="StartServerButton_Click"/>
                    <Button x:Name="StopServerButton" Content="停止服务" Style="{StaticResource ModernButton}"
                            Padding="20,12" Margin="10,0,0,0" IsEnabled="False"
                            Click="StopServerButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="监听端口" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="PortInput" Style="{StaticResource ModernTextBox}"
                             Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"
                             Text="8080"/>

                    <TextBlock Text="网站根目录" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,15,0,0"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RootPathInput" Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45"/>
                        <Button x:Name="BrowseButton" Grid.Column="1" Content="浏览"
                                Style="{StaticResource ModernButton}" Margin="10,0,0,0" Padding="15,10"
                                Click="BrowseButton_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="默认首页" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="DefaultPageInput" Style="{StaticResource ModernTextBox}"
                             Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"
                             Text="index.html"/>

                    <TextBlock Text="启用目录浏览" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,15,0,0"/>
                    <CheckBox x:Name="EnableDirectoryBrowsingCheckBox"
                              Foreground="{StaticResource TextBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ModernCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="访问日志" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" x:Name="AccessLogDataGrid" AutoGenerateColumns="False"
                          Background="Transparent" BorderThickness="0"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="150"
                                            Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DataGridTextColumn Header="IP地址" Binding="{Binding IpAddress}" Width="120"
                                            Foreground="{StaticResource TextBrush}"/>
                        <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="80"
                                            Foreground="{StaticResource TextBrush}"/>
                        <DataGridTextColumn Header="路径" Binding="{Binding Path}" Width="*"
                                            Foreground="{StaticResource TextBrush}"/>
                        <DataGridTextColumn Header="状态码" Binding="{Binding StatusCode}" Width="80"
                                            Foreground="{StaticResource TextSecondaryBrush}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
