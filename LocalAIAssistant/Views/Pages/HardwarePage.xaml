<Page x:Class="LocalAIAssistant.Views.Pages.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="硬件监控">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="硬件监控" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CPU 信息" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                        <TextBlock x:Name="CpuNameText" Text="-" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CpuCoresText" Text="核心数: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="CpuUsageText" Text="使用率: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="CpuTempText" Text="温度: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="内存信息" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                        <TextBlock x:Name="MemoryTotalText" Text="总内存: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="MemoryUsedText" Text="已使用: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="MemoryFreeText" Text="可用: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <ProgressBar x:Name="MemoryProgressBar" Style="{StaticResource ModernProgressBar}"
                                     Value="0" Maximum="100" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="GPU 信息" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                        <TextBlock x:Name="GpuNameText" Text="-" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="GpuMemoryText" Text="显存: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="GpuUsageText" Text="使用率: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="GpuTempText" Text="温度: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="存储信息" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                        <TextBlock x:Name="DiskTotalText" Text="总容量: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="DiskUsedText" Text="已使用: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <TextBlock x:Name="DiskFreeText" Text="可用: -" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                        <ProgressBar x:Name="DiskProgressBar" Style="{StaticResource ModernProgressBar}"
                                     Value="0" Maximum="100" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="网络状态" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="下载速度" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="DownloadSpeedText" Text="0 KB/s" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="上传速度" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="UploadSpeedText" Text="0 KB/s" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource ModernCard}">
                <StackPanel>
                    <TextBlock Text="磁盘分区" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="DiskPartitionsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2E" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Style="{StaticResource ModernProgressBar}"
                                                     Value="{Binding UsedPercent}" Maximum="100" Margin="20,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding FreeSpace}" FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
