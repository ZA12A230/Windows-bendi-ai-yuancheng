<Page x:Class="LocalAIAssistant.Views.Pages.CameraPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="远程摄像头">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="远程摄像头" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="摄像头状态" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Ellipse x:Name="CameraStatusIndicator" Width="12" Height="12" Fill="#EF4444"/>
                        <TextBlock x:Name="CameraStatusText" Text="未启动" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ComboBox x:Name="CameraComboBox" Width="200" Padding="10,8"
                              Background="{StaticResource SurfaceBrush}"
                              Foreground="{StaticResource TextBrush}"
                              BorderThickness="0" Margin="0,0,10,0"/>
                    <Button x:Name="StartCameraButton" Content="启动摄像头" Style="{StaticResource ModernButton}"
                            Padding="20,12" Click="StartCameraButton_Click"/>
                    <Button x:Name="StopCameraButton" Content="停止" Style="{StaticResource ModernButton}"
                            Padding="20,12" Margin="10,0,0,0" IsEnabled="False"
                            Click="StopCameraButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ModernCard}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="本地摄像头" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                    <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="12">
                        <Grid>
                            <TextBlock x:Name="LocalCameraStatusText" Text="摄像头未启动"
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="LocalCameraImage" Visibility="Collapsed" Stretch="Uniform"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource ModernCard}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="远程访问" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="访问地址" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="CameraAccessUrlText" Text="-" FontSize="14"
                                       Foreground="{StaticResource TextBrush}" Margin="0,5,0,0"/>
                            <CheckBox x:Name="EnableRemoteAccessCheckBox" Content="启用远程访问"
                                      Foreground="{StaticResource TextBrush}" Margin="0,15,0,0"
                                      Checked="EnableRemoteAccessCheckBox_Checked"
                                      Unchecked="EnableRemoteAccessCheckBox_Unchecked"/>
                            <CheckBox x:Name="EnableMicrophoneCheckBox" Content="启用麦克风"
                                      Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="12" Margin="0,15,0,0">
                            <TextBlock Text="远程查看器预览"
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
