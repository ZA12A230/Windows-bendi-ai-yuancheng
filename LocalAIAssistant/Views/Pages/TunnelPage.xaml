<Page x:Class="LocalAIAssistant.Views.Pages.TunnelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="内网穿透">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="内网穿透" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="穿透状态" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Ellipse x:Name="TunnelStatusIndicator" Width="12" Height="12" Fill="#EF4444"/>
                        <TextBlock x:Name="TunnelStatusText" Text="未连接" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="StartTunnelButton" Content="启动穿透" Style="{StaticResource ModernButton}"
                            Padding="20,12" Click="StartTunnelButton_Click"/>
                    <Button x:Name="StopTunnelButton" Content="停止" Style="{StaticResource ModernButton}"
                            Padding="20,12" Margin="10,0,0,0" IsEnabled="False"
                            Click="StopTunnelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="访问地址" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="PublicUrlText" Grid.Column="0" Text="-"
                               FontSize="16" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CopyUrlButton" Grid.Column="1" Content="复制"
                            Style="{StaticResource ModernButton}" Padding="15,8"
                            Click="CopyUrlButton_Click"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ModernCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="穿透配置" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="服务器地址" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="ServerAddressInput" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"
                                 Text="aiyuancheng.com"/>

                        <TextBlock Text="服务器端口" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,15,0,0"/>
                        <TextBox x:Name="ServerPortInput" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"
                                 Text="7000"/>

                        <TextBlock Text="认证Token" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,15,0,0"/>
                        <TextBox x:Name="AuthTokenInput" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="本地端口" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="LocalPortInput" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"
                                 Text="11434"/>

                        <TextBlock Text="远程端口" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,15,0,0"/>
                        <TextBox x:Name="RemotePortInput" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"
                                 Text="0"/>

                        <TextBlock Text="子域名 (可选)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,15,0,0"/>
                        <TextBox x:Name="SubdomainInput" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
