<Page x:Class="LocalAIAssistant.Views.Pages.ModelsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="模型管理">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="模型管理" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="下载新模型" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ModelNameInput" Grid.Column="0" Style="{StaticResource ModernTextBox}"
                             Padding="15" FontSize="14" Height="45"/>
                    <Button x:Name="DownloadButton" Grid.Column="1" Content="下载"
                            Style="{StaticResource ModernButton}" Margin="15,0,0,0" Padding="30,12"
                            Click="DownloadButton_Click"/>
                </Grid>

                <TextBlock Text="推荐模型: llama2, llama2:13b, mistral, codellama, deepseek-coder"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>

                <StackPanel x:Name="DownloadProgressPanel" Visibility="Collapsed" Margin="0,15,0,0">
                    <TextBlock x:Name="DownloadStatusText" Text="下载中..."
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ProgressBar x:Name="DownloadProgressBar" Style="{StaticResource ModernProgressBar}"
                                 Value="0" Maximum="100" Margin="0,10,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="已安装模型" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" x:Name="ModelsDataGrid" AutoGenerateColumns="False"
                          Background="Transparent" BorderThickness="0"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          CanUserAddRows="False" CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="模型名称" Binding="{Binding Name}" Width="*"
                                            Foreground="{StaticResource TextBrush}"/>
                        <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="100"
                                            Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DataGridTextColumn Header="修改时间" Binding="{Binding Modified}" Width="150"
                                            Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DataGridTemplateColumn Header="操作" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="删除" Style="{StaticResource ModernButton}"
                                            Padding="10,5" FontSize="12"
                                            Click="DeleteModel_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
