<Page x:Class="LocalAIAssistant.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="仪表盘">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="系统概览" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,30"/>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,30">
                <Border Style="{StaticResource ModernCard}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="CPU使用率" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CpuUsageText" Text="0%" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
                        <ProgressBar x:Name="CpuProgress" Style="{StaticResource ModernProgressBar}"
                                     Value="0" Maximum="100" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCard}" Margin="15,0,15,0">
                    <StackPanel>
                        <TextBlock Text="内存使用" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="MemoryUsageText" Text="0 GB" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
                        <ProgressBar x:Name="MemoryProgress" Style="{StaticResource ModernProgressBar}"
                                     Value="0" Maximum="100" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCard}" Margin="15,0,15,0">
                    <StackPanel>
                        <TextBlock Text="GPU使用率" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="GpuUsageText" Text="0%" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
                        <ProgressBar x:Name="GpuProgress" Style="{StaticResource ModernProgressBar}"
                                     Value="0" Maximum="100" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCard}" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="网络速度" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="NetworkSpeedText" Text="0 KB/s" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
                        <TextBlock Text="↓ 下载 ↑ 上传" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ModernCard}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Ollama 状态" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse x:Name="OllamaStatusIndicator" Width="12" Height="12" Fill="#EF4444"/>
                            <TextBlock x:Name="OllamaStatusText" Text="未运行" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="OllamaVersionText" Text="版本: -" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button x:Name="StartOllamaButton" Content="启动 Ollama"
                                Style="{StaticResource ModernButton}" Margin="0,15,0,0"
                                Click="StartOllamaButton_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ModernCard}" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="已安装模型" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                        <ListBox x:Name="ModelsListBox" Background="Transparent" BorderThickness="0"
                                 MaxHeight="150">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource ModernCard}">
                <StackPanel>
                    <TextBlock Text="快速操作" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                    <UniformGrid Columns="4">
                        <Button Content="打开AI对话" Style="{StaticResource ModernButton}" Margin="0,0,10,0"
                                Click="OpenAIChat_Click"/>
                        <Button Content="下载模型" Style="{StaticResource ModernButton}" Margin="10,0,10,0"
                                Click="DownloadModel_Click"/>
                        <Button Content="启动内网穿透" Style="{StaticResource ModernButton}" Margin="10,0,10,0"
                                Click="StartTunnel_Click"/>
                        <Button Content="远程桌面" Style="{StaticResource ModernButton}" Margin="10,0,0,0"
                                Click="OpenRemoteDesktop_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
