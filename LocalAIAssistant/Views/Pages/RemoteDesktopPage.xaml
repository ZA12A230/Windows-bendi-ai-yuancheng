<Page x:Class="LocalAIAssistant.Views.Pages.RemoteDesktopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="远程桌面">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="远程桌面" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="远程访问地址" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="RemoteAddressText" Text="未启动" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,5,0,0"/>
                    <TextBlock x:Name="ConnectionCodeText" Text="连接码: -" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="StartServerButton" Content="启动服务" Style="{StaticResource ModernButton}"
                            Padding="20,12" Click="StartServerButton_Click"/>
                    <Button x:Name="StopServerButton" Content="停止服务" Style="{StaticResource ModernButton}"
                            Padding="20,12" Margin="10,0,0,0" IsEnabled="False"
                            Click="StopServerButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="连接到远程设备" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="RemoteHostInput" Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45"/>
                        <Button x:Name="ConnectButton" Grid.Column="1" Content="连接"
                                Style="{StaticResource ModernButton}" Margin="15,0,0,0" Padding="30,12"
                                Click="ConnectButton_Click"/>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="输入远程地址或连接码"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>

                    <Border Grid.Row="2" Background="#1A1A2E" CornerRadius="12" Margin="0,20,0,0">
                        <Grid>
                            <TextBlock x:Name="ConnectionStatusText" Text="未连接"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <MediaElement x:Name="RemoteVideoControl" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
