<Page x:Class="LocalAIAssistant.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="设置">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="设置" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="启动设置" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                    <CheckBox x:Name="AutoStartCheckBox" Content="开机自启动"
                              Foreground="{StaticResource TextBrush}" FontSize="14"
                              Checked="AutoStartCheckBox_Checked"
                              Unchecked="AutoStartCheckBox_Unchecked"/>

                    <CheckBox x:Name="MinimizeToTrayCheckBox" Content="最小化到系统托盘"
                              Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,10,0,0"
                              IsChecked="True"/>

                    <CheckBox x:Name="StartMinimizedCheckBox" Content="启动时最小化"
                              Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,10,0,0"/>

                    <CheckBox x:Name="AutoStartOllamaCheckBox" Content="自动启动 Ollama"
                              Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,10,0,0"
                              IsChecked="True"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Ollama 设置" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                    <TextBlock Text="Ollama 安装路径" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OllamaPathInput" Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Padding="15" FontSize="14" Height="45"/>
                        <Button x:Name="BrowseOllamaButton" Grid.Column="1" Content="浏览"
                                Style="{StaticResource ModernButton}" Margin="10,0,0,0" Padding="15,10"
                                Click="BrowseOllamaButton_Click"/>
                    </Grid>

                    <TextBlock Text="默认模型" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,15,0,0"/>
                    <ComboBox x:Name="DefaultModelComboBox" Width="300" Padding="10,8"
                              Background="{StaticResource SurfaceBrush}"
                              Foreground="{StaticResource TextBrush}"
                              BorderThickness="0" Margin="0,5,0,0" HorizontalAlignment="Left"/>

                    <TextBlock Text="API 端口" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,15,0,0"/>
                    <TextBox x:Name="OllamaPortInput" Style="{StaticResource ModernTextBox}"
                             Padding="15" FontSize="14" Height="45" Width="200"
                             Text="11434" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="息屏设置" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                    <CheckBox x:Name="EnableScreenOffCheckBox" Content="启用息屏功能"
                              Foreground="{StaticResource TextBrush}" FontSize="14"
                              Checked="EnableScreenOffCheckBox_Checked"
                              Unchecked="EnableScreenOffCheckBox_Unchecked"/>

                    <TextBlock Text="启用后，可以通过快捷键或系统菜单快速关闭显示器（不锁屏）"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>

                    <Button x:Name="ScreenOffButton" Content="立即息屏"
                            Style="{StaticResource ModernButton}" Margin="0,15,0,0" Padding="20,12"
                            Click="ScreenOffButton_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource ModernCard}">
                <StackPanel>
                    <TextBlock Text="关于" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                    <TextBlock Text="本地AI助手 v1.0.0" FontSize="14"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="一个集成本地AI、远程访问、硬件监控的Windows桌面应用"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>

                    <TextBlock Text="技术栈: C# / .NET 8 / WPF"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>

                    <Button x:Name="CheckUpdateButton" Content="检查更新"
                            Style="{StaticResource ModernButton}" Margin="0,15,0,0" Padding="20,12"
                            Click="CheckUpdateButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
