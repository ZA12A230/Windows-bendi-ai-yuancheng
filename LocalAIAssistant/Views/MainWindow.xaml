<Window x:Class="LocalAIAssistant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="本地AI助手" Height="800" Width="1200"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <tb:TaskbarIcon x:Key="NotifyIcon" ToolTipText="本地AI助手"
                        TrayMouseDoubleClick="NotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口" Click="ShowWindowMenuItem_Click"/>
                    <MenuItem Header="AI设置" Click="OpenSettingsMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Window.Resources>

    <Grid>
        <Border x:Name="WindowBorder" Background="#CC1E1E2E" CornerRadius="20"
                BorderBrush="#404060" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="0"/>
            </Border.Effect>
        </Border>

        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="20,0">
                        <TextBlock Text="本地AI助手" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10">
                        <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                                Width="40" Height="40" Content="─" FontSize="14"
                                Background="Transparent" Foreground="{StaticResource TextBrush}"
                                BorderThickness="0" Style="{StaticResource ModernButton}"/>
                        <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                                Width="40" Height="40" Content="□" FontSize="14"
                                Background="Transparent" Foreground="{StaticResource TextBrush}"
                                BorderThickness="0" Style="{StaticResource ModernButton}"/>
                        <Button x:Name="CloseButton" Click="CloseButton_Click"
                                Width="40" Height="40" Content="✕" FontSize="14"
                                Background="Transparent" Foreground="{StaticResource TextBrush}"
                                BorderThickness="0" Style="{StaticResource ModernButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="0,0,0,20">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="NavDashboard" GroupName="Nav" IsChecked="True"
                                     Content="仪表盘" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="Dashboard"/>
                        <RadioButton x:Name="NavAIChat" GroupName="Nav"
                                     Content="AI对话" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="AIChat"/>
                        <RadioButton x:Name="NavModels" GroupName="Nav"
                                     Content="模型管理" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="Models"/>
                        <RadioButton x:Name="NavHardware" GroupName="Nav"
                                     Content="硬件监控" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="Hardware"/>
                        <RadioButton x:Name="NavRemoteDesktop" GroupName="Nav"
                                     Content="远程桌面" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="RemoteDesktop"/>
                        <RadioButton x:Name="NavCamera" GroupName="Nav"
                                     Content="远程摄像头" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="Camera"/>
                        <RadioButton x:Name="NavTunnel" GroupName="Nav"
                                     Content="内网穿透" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="Tunnel"/>
                        <RadioButton x:Name="NavWebServer" GroupName="Nav"
                                     Content="Web服务" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="WebServer"/>
                        <RadioButton x:Name="NavSettings" GroupName="Nav"
                                     Content="设置" Style="{StaticResource NavRadioButton}"
                                     Click="NavButton_Click" Tag="Settings"/>
                    </StackPanel>
                </Border>

                <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
